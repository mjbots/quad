common --noenable_bzlmod
build --incompatible_enable_cc_toolchain_resolution

build --define CLANG=true

# Sadly, Eigen/C++ still hasn't figured out how to reliably get
# alignment correct.  Lets just disable it for now.
build --copt -DEIGEN_DONT_ALIGN_STATICALLY

# The default (host) build and the --config=pi cross build both select
# rpi_bazel's clang toolchains via Bazel's platform-based toolchain
# resolution (the host k8 toolchain is registered with
# register_host = True in WORKSPACE).  --cpu is retained for --config=pi
# so the //:raspberrypi config_setting (cpu=armeabihf) keeps matching
# and so the bazel-out directory stays distinct from the host build.
build:pi --platforms=@rpi_bazel//:armeabihf
build:pi --cpu=armeabihf
build:pi --define COM_GITHUB_MJBOTS_RASPBERRYPI=1

build --strip=never

build -c opt
build --copt -D_FILE_OFFSET_BITS=64
build --copt -D_LARGEFILE_SOURCE
build --copt -D_LARGEFILE64_SOURCE

test --test_output=errors

build --workspace_status_command=tools/workspace_status.sh

build --stamp
